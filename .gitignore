# ── Python & Bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Virtual Environments ──────────────────────────────────────────────────────
# Common names for virtual envs
venv/
env/
.venv/
.env/

# ── Environment Variables (CRITICAL) ──────────────────────────────────────────
# Never commit your API keys
.env
.flaskenv

# ── Database ──────────────────────────────────────────────────────────────────
# Ignore SQLite databases
*.db
*.sqlite3
heritage.db

# ── User Uploads ──────────────────────────────────────────────────────────────
# Ignore uploaded images but keep the folder structure if you add a .gitkeep later
static/uploads/*
!static/uploads/.gitkeep

# ── IDE & Editor Settings ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS Generated Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini